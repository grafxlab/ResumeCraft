# ── Database ─────────────────────────────────────────────
# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://jobs:jobs@localhost:5432/jobs

# ── Job sources ──────────────────────────────────────────
# Adzuna: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us

# JSearch via RapidAPI: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key
JSEARCH_HOST=jsearch.p.rapidapi.com

# ── LLM provider (openai | anthropic) ────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── App ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Use a long random value outside local development.
AUTH_SECRET_KEY=replace_with_a_long_random_secret
# Creates a verified Power-plan administrator on startup, or promotes an
# existing account with this email without changing its password.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_password

# SMTP confirmation email. Leave blank only for local development; confirmation
# links are logged by the backend when SMTP is not configured.
SMTP_HOST=ssmtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true

# Google OAuth callback URL: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
